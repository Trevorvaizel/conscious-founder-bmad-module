# Audio files - NEVER commit these
.claude/audio/
*.wav
*.onnx

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Vector database
data/vector-embeddings.db
data/*.db
*.db-journal
*.db-wal

# Node directories
nodes/injected/*
nodes/transformed/*
nodes/published/*
nodes/deepening/*
!nodes/injected/.gitkeep
!nodes/transformed/.gitkeep
!nodes/published/.gitkeep
!nodes/deepening/.gitkeep

# Logs
*.log
altitude-setup.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Backup directories
*.backup.*/
*~
*.bak

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
TEST_COMMIT.md

# Archive (local only)
.archive/
